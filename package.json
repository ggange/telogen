{
  "name": "telogen",
  "version": "0.1.4",
  "description": "Generate AI-readable markdown from your React source. No proxy, no runtime cost.",
  "type": "module",
  "bin": {
    "telogen": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggange/telogen.git"
  },
  "homepage": "https://github.com/ggange/telogen#readme",
  "bugs": "https://github.com/ggange/telogen/issues",
  "keywords": [
    "llm",
    "ai",
    "agents",
    "react",
    "nextjs",
    "markdown",
    "llms.txt"
  ],
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
